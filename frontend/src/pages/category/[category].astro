---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import CategoriesHeader from "../../components/categories/CategoriesHeader.astro";
import Breadcrumbs from "../../components/ui/Breadcrumbs.astro";
import CardProduct from "../../components/products/CardProduct.astro";
import ProductSidebar from "../../components/products/ProductSidebar.astro";
import { marcaService } from "../../services/marcaService";
import { productService } from "../../services/productService";
import {
    productoToCardData,
    slugify,
} from "../../services/productAdapter";
import { getImageUrl } from "../../services/api";
import type { Marca, Producto } from "../../services/types";

let marcas: Marca[] = [];
try {
    marcas = await marcaService.listar();
} catch (e) {
    console.warn("[category] No se pudieron cargar marcas:", e);
}

const slugParam = Astro.params.category || "";
const marca = marcas.find((m) => slugify(m.nombre) === slugParam);

if (!marca) {
    return Astro.redirect("/404");
}

let products: Producto[] = [];
try {
    products = await productService.porMarca(marca.id);
} catch (e) {
    console.warn(`[category] No se pudieron cargar productos de ${marca.nombre}:`, e);
}

const cards = products
    .filter((p) => p.estado === 1)
    .map(productoToCardData);

const breadcrumbItems = [
    { label: "Inicio", href: "/" },
    { label: marca.nombre },
];

const subcategories = [
    ...new Set(
        products
            .map((p) => p.nombre.split(" ")[0])
            .filter((s) => s.toLowerCase() !== marca.nombre.toLowerCase())
    ),
].map((sub) => {
    const slug = slugify(sub);
    return {
        name: sub,
        slug,
        count: products.filter(
            (p) => slugify(p.nombre.split(" ")[0]) === slug
        ).length,
    };
});

const allPrices = products.map((p) => p.precio);
const minPrice = allPrices.length ? Math.floor(Math.min(...allPrices)) : 0;
const maxPrice = allPrices.length ? Math.ceil(Math.max(...allPrices)) : 0;

const headerImage = cards[0]?.images[0] || getImageUrl(null);
---

<Layout title={`${marca.nombre} | Smartoryx`}>
    <CategoriesHeader title={marca.nombre} image={headerImage} />

    <div class="bg-base-100 min-h-screen pb-20 pt-10">
        <div class="max-w-7xl mx-auto px-6">
            <div id="breadcrumbs-container" class="mb-6">
                <Breadcrumbs items={breadcrumbItems} />
            </div>

            <div class="flex flex-col lg:flex-row gap-8">
                <div class="lg:w-1/4">
                    <div class="sticky top-24">
                        <ProductSidebar
                            subcategories={subcategories}
                            brands={[]}
                            minPrice={minPrice}
                            maxPrice={maxPrice}
                            categorySlug={Astro.params.category!}
                        />
                    </div>
                </div>

                <div class="lg:w-3/4">
                    <div class="flex items-center justify-between mb-6 pb-4 border-b border-white/10">
                        <p class="text-sm text-white font-medium">
                            <span id="product-count" class="text-primary font-bold">{cards.length}</span> productos encontrados
                        </p>
                        <div class="flex items-center gap-2">
                            <span class="text-sm text-white font-medium">Ordenar por:</span>
                            <select id="sort-select" class="select select-bordered select-sm bg-base-100 text-white border-white/20 focus:border-primary">
                                <option value="relevance" class="bg-base-100 text-white">Relevancia</option>
                                <option value="price-asc" class="bg-base-100 text-white">Precio: menor a mayor</option>
                                <option value="price-desc" class="bg-base-100 text-white">Precio: mayor a menor</option>
                                <option value="name-asc" class="bg-base-100 text-white">Nombre: A-Z</option>
                            </select>
                        </div>
                    </div>

                    <main class="py-4">
                        {cards.length === 0 ? (
                            <div
                                class="text-center py-24 bg-base-200 rounded-3xl border-2 border-dashed border-white/20"
                            >
                                <p class="text-white/80 font-bold uppercase tracking-widest">
                                    No hay productos disponibles de {marca.nombre} por el momento
                                </p>
                            </div>
                        ) : (
                            <div
                                id="products-grid"
                                class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 animate-fade-in"
                            >
                                {cards.map((product) => (
                                    <div
                                        class="product-item transition-all duration-300"
                                        data-brand={slugify(product.category || "").toLowerCase()}
                                        data-price={product.price}
                                        data-name={product.name.toLowerCase()}
                                    >
                                        <CardProduct
                                            title={product.title}
                                            price={product.price}
                                            images={product.images}
                                            stock={product.stock}
                                            slug={product.slug}
                                        />
                                    </div>
                                ))}
                            </div>
                        )}

                        <div
                            id="no-products-msg"
                            class="hidden text-center py-24 bg-base-200 rounded-3xl border-2 border-dashed border-white/20"
                        >
                            <p class="text-white/80 font-bold uppercase tracking-widest">
                                No se encontraron productos con estos filtros
                            </p>
                        </div>
                    </main>
                </div>
            </div>
        </div>
    </div>
</Layout>

<script>
    function filterAndSortProducts() {
        const urlParams = new URLSearchParams(window.location.search);
        const brand = urlParams.get("brand")?.toLowerCase();
        const minPrice = parseFloat(urlParams.get("min") || "0");
        const maxPrice = parseFloat(urlParams.get("max") || "99999");
        const sortBy = (document.getElementById("sort-select") as HTMLSelectElement)?.value || "relevance";

        const products = document.querySelectorAll(".product-item");
        const noProductsMsg = document.getElementById("no-products-msg");
        const productCount = document.getElementById("product-count");
        let visibleCount = 0;

        const visibleProducts: { el: HTMLElement; price: number; name: string }[] = [];

        products.forEach((el) => {
            const item = el as HTMLElement;
            const itemBrand = item.dataset.brand;
            const itemPrice = parseFloat(item.dataset.price || "0");
            const itemName = item.dataset.name || "";

            let visible = true;

            if (brand && itemBrand !== brand) visible = false;
            if (itemPrice < minPrice || itemPrice > maxPrice) visible = false;

            if (visible) {
                item.classList.remove("hidden");
                visibleCount++;
                visibleProducts.push({ el: item, price: itemPrice, name: itemName });
            } else {
                item.classList.add("hidden");
            }
        });

        if (sortBy === "price-asc") {
            visibleProducts.sort((a, b) => a.price - b.price);
        } else if (sortBy === "price-desc") {
            visibleProducts.sort((a, b) => b.price - a.price);
        } else if (sortBy === "name-asc") {
            visibleProducts.sort((a, b) => a.name.localeCompare(b.name));
        }

        const grid = document.getElementById("products-grid");
        if (grid) {
            visibleProducts.forEach((p) => grid.appendChild(p.el));
        }

        if (productCount) productCount.textContent = visibleCount.toString();

        if (visibleCount === 0) {
            noProductsMsg?.classList.remove("hidden");
        } else {
            noProductsMsg?.classList.add("hidden");
        }
    }

    function initSortHandler() {
        const sortSelect = document.getElementById("sort-select");
        if (sortSelect) {
            sortSelect.addEventListener("change", filterAndSortProducts);
        }
    }

    filterAndSortProducts();
    initSortHandler();

    document.addEventListener("astro:page-load", () => {
        filterAndSortProducts();
        initSortHandler();
    });
</script>

<style>
    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    .animate-fade-in {
        animation: fadeIn 0.6s ease-out forwards;
    }
</style>
