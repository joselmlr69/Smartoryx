---
import Layout from "../../layouts/Layout.astro";
import CategoriesHeader from "../../components/categories/CategoriesHeader.astro";
import Breadcrumbs from "../../components/ui/Breadcrumbs.astro";
import CardProduct from "../../components/products/CardProduct.astro";
import ProductSidebar from "../../components/products/ProductSidebar.astro";
import { products } from "../../data/products";
import { categories } from "../../data/home";

export async function getStaticPaths() {
    const uniqueCategories = [...new Set(products.map((p) => p.category))];

    return uniqueCategories.map((category) => {
        const categoryData = categories.find(
            (c) => c.name.toLowerCase() === category.toLowerCase(),
        );
        const categorySlug = category.toLowerCase();
        return {
            params: { category: categorySlug },
            props: {
                categoryName: category,
                categoryProducts: products.filter(
                    (p) => p.category === category,
                ),
                image: categoryData?.image,
            },
        };
    });
}

const { categoryName, categoryProducts, image } = Astro.props;

const breadcrumbItems = [{ label: "Inicio", href: "/" }, { label: categoryName }];

const subcategories = [...new Set(categoryProducts.map((p) => p.subcategory).filter(Boolean))].map((sub) => {
    const slug = sub!.toLowerCase();
    return {
        name: sub!,
        slug,
        count: categoryProducts.filter((p) => p.subcategory?.toLowerCase() === slug).length,
    };
});

const brands = [...new Set(categoryProducts.map((p) => p.name.split(" ")[0]))].map((brand) => {
    const slug = brand.toLowerCase();
    return {
        name: brand,
        slug,
        count: categoryProducts.filter((p) => p.name.startsWith(brand)).length,
    };
});

const allPrices = categoryProducts.map((p) => p.price);
const minPrice = Math.floor(Math.min(...allPrices));
const maxPrice = Math.ceil(Math.max(...allPrices));
---

<Layout title={`${categoryName} | Smartoryx`}>
    <CategoriesHeader title={categoryName} image={image} />

    <div class="bg-base-100 min-h-screen pb-20 pt-10">
        <div class="max-w-7xl mx-auto px-6">
            <div id="breadcrumbs-container" class="mb-6">
                <Breadcrumbs items={breadcrumbItems} />
            </div>

            <div class="flex flex-col lg:flex-row gap-8">
                <!-- Sidebar -->
                <div class="lg:w-1/4">
                    <div class="sticky top-24">
                        <ProductSidebar
                            subcategories={subcategories}
                            brands={brands}
                            minPrice={minPrice}
                            maxPrice={maxPrice}
                            categorySlug={Astro.params.category!}
                        />
                    </div>
                </div>

                <!-- Products Grid -->
                <div class="lg:w-3/4">
                    <!-- Sort Bar -->
                    <div class="flex items-center justify-between mb-6 pb-4 border-b border-base-300">
                        <p class="text-sm text-base-content/60">
                            <span id="product-count">{categoryProducts.length}</span> productos encontrados
                        </p>
                        <div class="flex items-center gap-2">
                            <span class="text-sm text-base-content/60">Ordenar por:</span>
                            <select id="sort-select" class="select select-bordered select-sm">
                                <option value="relevance">Relevancia</option>
                                <option value="price-asc">Precio: menor a mayor</option>
                                <option value="price-desc">Precio: mayor a menor</option>
                                <option value="name-asc">Nombre: A-Z</option>
                            </select>
                        </div>
                    </div>

                    <main class="py-4">
                        <div
                            id="products-grid"
                            class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 animate-fade-in"
                        >
                            {
                                categoryProducts.map((product) => (
                                    <div
                                        class="product-item transition-all duration-300"
                                        data-subcategory={product.subcategory?.toLowerCase() || ""}
                                        data-brand={product.name.split(" ")[0].toLowerCase()}
                                        data-price={product.price}
                                        data-name={product.name.toLowerCase()}
                                    >
                                        <CardProduct
                                            title={product.title}
                                            price={product.price}
                                            images={product.images}
                                            stock={product.stock}
                                            slug={product.slug}
                                        />
                                    </div>
                                ))
                            }
                        </div>

                        <div
                            id="no-products-msg"
                            class="hidden text-center py-24 bg-base-200 rounded-3xl border-2 border-dashed border-base-300"
                        >
                            <p class="text-base-content/40 font-bold uppercase tracking-widest">
                                No se encontraron productos con estos filtros
                            </p>
                        </div>
                    </main>
                </div>
            </div>
        </div>
    </div>
</Layout>

<script>
    function filterAndSortProducts() {
        const urlParams = new URLSearchParams(window.location.search);
        const subCategory = urlParams.get("sub")?.toLowerCase();
        const brand = urlParams.get("brand")?.toLowerCase();
        const minPrice = parseFloat(urlParams.get("min") || "0");
        const maxPrice = parseFloat(urlParams.get("max") || "99999");
        const sortBy = (document.getElementById("sort-select") as HTMLSelectElement)?.value || "relevance";

        const products = document.querySelectorAll(".product-item");
        const noProductsMsg = document.getElementById("no-products-msg");
        const productCount = document.getElementById("product-count");
        let visibleCount = 0;

        const visibleProducts: { el: HTMLElement; price: number; name: string }[] = [];

        products.forEach((el) => {
            const item = el as HTMLElement;
            const itemSub = item.dataset.subcategory;
            const itemBrand = item.dataset.brand;
            const itemPrice = parseFloat(item.dataset.price || "0");
            const itemName = item.dataset.name || "";

            let visible = true;

            if (subCategory && itemSub !== subCategory) visible = false;
            if (brand && itemBrand !== brand) visible = false;
            if (itemPrice < minPrice || itemPrice > maxPrice) visible = false;

            if (visible) {
                item.classList.remove("hidden");
                visibleCount++;
                visibleProducts.push({ el: item, price: itemPrice, name: itemName });
            } else {
                item.classList.add("hidden");
            }
        });

        // Sort visible products
        if (sortBy === "price-asc") {
            visibleProducts.sort((a, b) => a.price - b.price);
        } else if (sortBy === "price-desc") {
            visibleProducts.sort((a, b) => b.price - a.price);
        } else if (sortBy === "name-asc") {
            visibleProducts.sort((a, b) => a.name.localeCompare(b.name));
        }

        // Reorder DOM elements
        const grid = document.getElementById("products-grid");
        if (grid) {
            visibleProducts.forEach((p) => grid.appendChild(p.el));
        }

        // Update count
        if (productCount) productCount.textContent = visibleCount.toString();

        // Show "No products" message
        if (visibleCount === 0) {
            noProductsMsg?.classList.remove("hidden");
        } else {
            noProductsMsg?.classList.add("hidden");
        }
    }

    function initSortHandler() {
        const sortSelect = document.getElementById("sort-select");
        if (sortSelect) {
            sortSelect.addEventListener("change", filterAndSortProducts);
        }
    }

    filterAndSortProducts();
    initSortHandler();

    document.addEventListener("astro:page-load", () => {
        filterAndSortProducts();
        initSortHandler();
    });
</script>

<style>
    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    .animate-fade-in {
        animation: fadeIn 0.6s ease-out forwards;
    }
</style>
