---
import Layout from "../layouts/Layout.astro";
import CheckoutFlow from "../components/checkout/CheckoutFlow";
---

<Layout>
    <div class="bg-slate-50 min-h-screen py-12 md:py-20 px-4">
        <div class="max-w-3xl mx-auto">
            <a
                href="/"
                class="inline-flex items-center gap-2 text-slate-400 hover:text-slate-950 font-bold text-[10px] uppercase tracking-widest transition-colors mb-8 group"
            >
                ← Volver a la Tienda
            </a>

            <div class="space-y-4 mb-8">
                <span class="text-primary font-black uppercase text-xs tracking-[0.3em] italic">
                    Pago Seguro
                </span>
                <h1 class="text-4xl md:text-5xl font-black text-slate-950 uppercase tracking-tighter italic">
                    Finalizar Pedido
                </h1>
                <p class="text-slate-500 font-medium">
                    Selecciona tu dirección, método de pago y confirma tu compra.
                </p>
            </div>

            <CheckoutFlow client:only="react" />
        </div>
    </div>
</Layout>
