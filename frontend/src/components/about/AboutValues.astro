---
import AboutCard from "./AboutCard.astro";

const values = [
    {
        title: "Calidad Sin Compromiso",
        description:
            "Solo trabajamos con marcas que cumplen nuestros rigurosos estándares de rendimiento, durabilidad y diseño.",
        icon: "lucide:award",
    },
    {
        title: "Envío Rápido",
        description:
            "Logística de primer nivel para asegurar que tu celular llegue de forma segura y rápida a cualquier parte del país.",
        icon: "lucide:truck",
    },
    {
        title: "Soporte Experto",
        description:
            "Nuestro equipo de especialistas está disponible para ayudarte a encontrar el dispositivo perfecto para tus necesidades.",
        icon: "lucide:headset",
    },
];
---

<section class="py-20 bg-slate-50 px-4">
    <div class="max-w-7xl mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-16">
            <span
                class="text-primary font-bold uppercase tracking-widest text-sm mb-4 block"
                >Nuestros Valores</span
            >
            <h2
                class="text-3xl md:text-5xl font-black text-slate-900 uppercase"
            >
                Lo Que Nos Impulsa
            </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {values.map((value) => <AboutCard {...value} />)}
        </div>
    </div>
</section>
