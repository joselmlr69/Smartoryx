---
interface Props {
    minPrice: number;
    maxPrice: number;
    activeMinPrice?: number;
    activeMaxPrice?: number;
    categorySlug: string;
}

const { minPrice, maxPrice, activeMinPrice, activeMaxPrice, categorySlug } = Astro.props;
---

<aside class="space-y-8 text-base-content">
    <!-- Search by name -->
    <div class="border-b border-white/10 pb-6">
        <h3 class="font-bold text-lg mb-4 text-white">Buscar por nombre</h3>
        <div class="relative">
            <input
                type="search"
                id="search-input"
                placeholder="Ej. Galaxy, iPhone, Redmi..."
                class="input input-bordered input-sm w-full bg-base-100 text-white border-white/20 focus:border-primary pr-8"
            />
            <button
                type="button"
                id="clear-search-btn"
                class="absolute right-2 top-1/2 -translate-y-1/2 text-white/50 hover:text-white hidden"
                aria-label="Limpiar búsqueda"
            >
                ✕
            </button>
        </div>
    </div>

    <!-- Availability -->
    <div class="border-b border-white/10 pb-6">
        <h3 class="font-bold text-lg mb-4 text-white">Disponibilidad</h3>
        <ul class="space-y-2">
            <li>
                <label class="flex items-center gap-3 py-2 px-3 rounded-lg cursor-pointer hover:bg-primary/20 text-base-content/80">
                    <input
                        type="radio"
                        name="stock-filter"
                        value="all"
                        class="radio radio-sm radio-primary"
                        checked
                    />
                    <span class="text-sm">Todos</span>
                </label>
            </li>
            <li>
                <label class="flex items-center gap-3 py-2 px-3 rounded-lg cursor-pointer hover:bg-primary/20 text-base-content/80">
                    <input
                        type="radio"
                        name="stock-filter"
                        value="in-stock"
                        class="radio radio-sm radio-primary"
                    />
                    <span class="text-sm">Solo en stock</span>
                </label>
            </li>
            <li>
                <label class="flex items-center gap-3 py-2 px-3 rounded-lg cursor-pointer hover:bg-primary/20 text-base-content/80">
                    <input
                        type="radio"
                        name="stock-filter"
                        value="out-of-stock"
                        class="radio radio-sm radio-primary"
                    />
                    <span class="text-sm">Agotados</span>
                </label>
            </li>
        </ul>
    </div>

    <!-- Price Range -->
    <div>
        <h3 class="font-bold text-lg mb-4 text-white">Rango de Precio</h3>
        <div class="px-2">
            <div class="flex justify-between text-sm text-white/80 mb-2 font-medium">
                <span id="min-price-label">S/ {activeMinPrice ?? minPrice}</span>
                <span id="max-price-label">S/ {activeMaxPrice ?? maxPrice}</span>
            </div>
            <div class="flex gap-4">
                <div class="flex-1">
                    <label class="text-xs text-white/70 block mb-1 font-semibold uppercase tracking-wider">Mínimo</label>
                    <input
                        type="number"
                        id="price-min"
                        class="input input-bordered input-sm w-full bg-base-100 text-white border-white/20 focus:border-primary"
                        min={minPrice}
                        max={maxPrice}
                        value={activeMinPrice ?? minPrice}
                    />
                </div>
                <div class="flex-1">
                    <label class="text-xs text-white/70 block mb-1 font-semibold uppercase tracking-wider">Máximo</label>
                    <input
                        type="number"
                        id="price-max"
                        class="input input-bordered input-sm w-full bg-base-100 text-white border-white/20 focus:border-primary"
                        min={minPrice}
                        max={maxPrice}
                        value={activeMaxPrice ?? maxPrice}
                    />
                </div>
            </div>
            <button
                id="apply-price-btn"
                class="btn btn-primary btn-sm w-full mt-4"
            >
                Aplicar
            </button>
            {(activeMinPrice || activeMaxPrice) && (
                <a
                    href={`?${activeMinPrice ? `min=${activeMinPrice}` : ""}${activeMaxPrice ? `${activeMinPrice ? "&" : ""}max=${activeMaxPrice}` : ""}`}
                    class="btn btn-ghost btn-xs w-full mt-2 text-white/70 hover:text-white"
                >
                    Limpiar filtros
                </a>
            )}
        </div>
    </div>
</aside>

<script>
    function initPriceFilter() {
        const applyBtn = document.getElementById("apply-price-btn");
        const minInput = document.getElementById("price-min") as HTMLInputElement;
        const maxInput = document.getElementById("price-max") as HTMLInputElement;

        if (!applyBtn || !minInput || !maxInput) return;

        applyBtn.addEventListener("click", () => {
            const urlParams = new URLSearchParams(window.location.search);
            const min = minInput.value;
            const max = maxInput.value;

            if (min) urlParams.set("min", min);
            else urlParams.delete("min");

            if (max) urlParams.set("max", max);
            else urlParams.delete("max");

            window.location.search = urlParams.toString();
        });
    }

    initPriceFilter();
    document.addEventListener("astro:page-load", initPriceFilter);
</script>
