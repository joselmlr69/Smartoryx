---
import "../styles/global.css";
import Navbar from "../components/navbar/NavBar.astro";
import AnnouncementBar from "../components/ui/AnnouncementBar.astro";
import Footer from "../components/footer/Footer.astro";
import ToasterComponent from "../components/ui/ToasterComponent";
import CartDrawer from "../components/cart/CartDrawer.astro";
---

<!doctype html>
<html lang="es" data-theme="smartoryx">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/logo.png" />
		<meta name="generator" content={Astro.generator} />
		<title>Smartoryx | Tienda de Celulares</title>
	</head>
	<body class="bg-white text-slate-900 min-h-screen">
		<AnnouncementBar />
		<Navbar />
		<main>
			<slot />
		</main>
		<Footer />
		<CartDrawer />
		<ToasterComponent client:load />
		<script>
			import { loadSesion, currentUser } from "../store/authStore";
			import { loadCarrito, currentCarrito } from "../store/cartStore";

			loadSesion();

			let lastUserId: number | null = null;
			currentUser.subscribe((u) => {
				const newId = u?.id ?? null;
				if (newId !== lastUserId) {
					lastUserId = newId;
					if (newId !== null) {
						loadCarrito();
					} else {
						currentCarrito.set(null);
					}
				}
			});
		</script>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
	}
</style>
